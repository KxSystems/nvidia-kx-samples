# --- Source agents (optional; each source appears in the UI only when its deps + key are present) ---
# Web search (firecrawl via MCP; also needs `npx firecrawl-mcp` Node package at runtime):
FIRECRAWL_API_KEY=
# News headlines + Alpha Vantage fallback for market data/fundamentals:
ALPHAVANTAGE_API_KEY=
# SEC EDGAR filings (identity email for the SEC user-agent; not a secret):
SEC_EDGAR_EMAIL=kxta@example.com
# FRED macroeconomic data (free key from https://fred.stlouisfed.org/docs/api/api_key.html):
FRED_API_KEY=
