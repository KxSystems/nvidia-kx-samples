# ============================================================================
# Data Flywheel — Local Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# docker compose reads .env automatically from the same directory.
# ============================================================================

# ---------- NVIDIA API Keys ----------
# Required: Your NVIDIA API key (from build.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Separate keys for LLM judge and embeddings.
# If unset, NVIDIA_API_KEY is used as fallback.
LLM_JUDGE_API_KEY=
EMB_API_KEY=

# ---------- KDB-X ----------
# Required: Email for KDB-X registry (from portal.dl.kx.com)
KDBAI_REGISTRY_EMAIL=

# Required: Bearer token for downloading KDB-X installer (from portal.dl.kx.com)
KDBAI_REGISTRY_TOKEN=

# Required: Base64-encoded KDB license string (from portal.dl.kx.com)
KDB_LICENSE_B64=

# Optional: KDB-X authentication credentials
# Leave empty to connect without authentication (fine for local dev).
KDBX_USERNAME=
KDBX_PASSWORD=

# ---------- Redis ----------
# Optional: Password for Redis. Leave empty for no-auth local dev.
REDIS_PASSWORD=

# ---------- Hugging Face ----------
# Optional: Hugging Face token for dataset / model access.
HF_TOKEN=

# ---------- Docker Compose ----------
# Set to "mlflow" to enable the MLflow tracking server, or leave empty.
COMPOSE_PROFILES=mlflow

# Image tag for docker-compose builds
TAG=0.3.0

# ============================================================================
# EKS Deployment Settings (used by deploy-eks.sh, eksctl-cluster.yaml, etc.)
# ============================================================================

# ---------- AWS ----------
AWS_PROFILE=terraform-sa
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=

# ---------- EKS Cluster ----------
EKS_CLUSTER_NAME=data-flywheel-dev

# ---------- VPC / Networking ----------
# Provide an existing VPC and subnets, or leave empty to let eksctl create new ones.
VPC_ID=
SUBNET_PUBLIC_2A=
SUBNET_PUBLIC_2B=
SUBNET_PRIVATE_2A=
SUBNET_PRIVATE_2B=

# ---------- ECR ----------
# ECR repository name (created automatically if missing)
ECR_REPO_NAME=data-flywheel-server
IMAGE_TAG=0.5.1
