        <mxCell id="p66b" edge="1" source="step6" target="step6b" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeWidth=2;strokeColor=#4a86c8;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Shutdown → Complete -->
        <mxCell id="p6b7" edge="1" source="step6b" target="step7" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeWidth=2;strokeColor=#4a86c8;">
