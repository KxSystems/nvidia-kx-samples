          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Parallel fan-in → Shutdown -->
        <mxCell id="p46b" edge="1" source="step4" target="step6b" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeWidth=2;strokeColor=#4a86c8;">
