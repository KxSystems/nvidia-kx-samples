        <mxCell id="p22b" edge="1" source="step2" target="step2b" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeWidth=2;strokeColor=#4a86c8;">
