          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- NIM Deploy → parallel fan-out -->
        <mxCell id="p34a" edge="1" source="step3" target="step4" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeWidth=2;strokeColor=#4a86c8;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p34b" edge="1" source="step3" target="step4b" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeWidth=2;strokeColor=#4a86c8;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p35" edge="1" source="step3" target="step5" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeWidth=2;strokeColor=#4a86c8;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- SFT → Custom Eval (chained within parallel branch) -->
